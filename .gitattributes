# Normalize text files to LF in the repository; check out native on each platform.
* text=auto

# Always LF — critical for shell scripts that run on Linux/macOS.
*.sh   text eol=lf
*.bash text eol=lf

# Always CRLF — Windows-only batch scripts.
*.bat text eol=crlf
*.cmd text eol=crlf

# Binaries: never normalize.
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
